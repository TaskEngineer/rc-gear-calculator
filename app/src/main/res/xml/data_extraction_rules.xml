<?xml version="1.0" encoding="utf-8"?>
<!--
   Android 12+ のバックアップ/転送ルール
   - cloud-backup: クラウドへのバックアップ（端末紛失時の復元用）
   - device-transfer: 端末間の直接転送
   参考: https://developer.android.com/about/versions/12/backup-restore
-->
<data-extraction-rules>
    <cloud-backup>
        <!-- 全データをクラウドバックアップ対象に含める（明示的な除外なし） -->
    </cloud-backup>
    <device-transfer>
        <!-- 全データを端末間転送対象に含める -->
    </device-transfer>
</data-extraction-rules>
