<?xml version="1.0" encoding="utf-8"?>
<!--
    ランチャーアイコン foreground（Step 12）。
    ティールのギア（リング + 12歯 + センターハブ）。
    - adaptive icon のセーフゾーン（中心から半径33）に収まるサイズ
    - monochrome（Android 13 テーマアイコン）でも破綻しないよう、
      穴は fillType=evenOdd で「本当の穴」として抜いている
-->
<vector xmlns:android="http://schemas.android.com/apk/res/android"
    android:width="108dp"
    android:height="108dp"
    android:viewportWidth="108"
    android:viewportHeight="108">

    <!-- リング（外周 r=23、内周 r=15）+ センターハブ（r=5）を evenOdd で一体描画 -->
    <path
        android:fillColor="#5DCAA5"
        android:fillType="evenOdd"
        android:pathData="M54,31 a23,23 0 1,0 0,46 a23,23 0 1,0 0,-46 z
                          M54,39 a15,15 0 1,0 0,30 a15,15 0 1,0 0,-30 z
                          M54,49 a5,5 0 1,0 0,10 a5,5 0 1,0 0,-10 z" />

    <!-- 歯 × 12（30度刻み）。リング外周に重ねて配置 -->
    <group android:pivotX="54" android:pivotY="54" android:rotation="0">
        <path android:fillColor="#5DCAA5" android:pathData="M50,26 h8 v10 h-8 z" />
    </group>
    <group android:pivotX="54" android:pivotY="54" android:rotation="30">
        <path android:fillColor="#5DCAA5" android:pathData="M50,26 h8 v10 h-8 z" />
    </group>
    <group android:pivotX="54" android:pivotY="54" android:rotation="60">
        <path android:fillColor="#5DCAA5" android:pathData="M50,26 h8 v10 h-8 z" />
    </group>
    <group android:pivotX="54" android:pivotY="54" android:rotation="90">
        <path android:fillColor="#5DCAA5" android:pathData="M50,26 h8 v10 h-8 z" />
    </group>
    <group android:pivotX="54" android:pivotY="54" android:rotation="120">
        <path android:fillColor="#5DCAA5" android:pathData="M50,26 h8 v10 h-8 z" />
    </group>
    <group android:pivotX="54" android:pivotY="54" android:rotation="150">
        <path android:fillColor="#5DCAA5" android:pathData="M50,26 h8 v10 h-8 z" />
    </group>
    <group android:pivotX="54" android:pivotY="54" android:rotation="180">
        <path android:fillColor="#5DCAA5" android:pathData="M50,26 h8 v10 h-8 z" />
    </group>
    <group android:pivotX="54" android:pivotY="54" android:rotation="210">
        <path android:fillColor="#5DCAA5" android:pathData="M50,26 h8 v10 h-8 z" />
    </group>
    <group android:pivotX="54" android:pivotY="54" android:rotation="240">
        <path android:fillColor="#5DCAA5" android:pathData="M50,26 h8 v10 h-8 z" />
    </group>
    <group android:pivotX="54" android:pivotY="54" android:rotation="270">
        <path android:fillColor="#5DCAA5" android:pathData="M50,26 h8 v10 h-8 z" />
    </group>
    <group android:pivotX="54" android:pivotY="54" android:rotation="300">
        <path android:fillColor="#5DCAA5" android:pathData="M50,26 h8 v10 h-8 z" />
    </group>
    <group android:pivotX="54" android:pivotY="54" android:rotation="330">
        <path android:fillColor="#5DCAA5" android:pathData="M50,26 h8 v10 h-8 z" />
    </group>
</vector>
